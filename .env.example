# Environment variables for atri
# This file is git-ignored; never commit real secrets.
# Loaded by src/main.py at startup via python-dotenv.

# ---- Main chat LLM / mem0 local_deploy / TTS (SiliconFlow by default) ----
SILICONFLOW_API_KEY=sk-xxxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# ---- Optional OpenAI provider branch in config/llm_config.yaml ----
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4

# ---- L3/L4 compression LLM ----
# base_url currently hard-coded in config/llm_config.yaml (same endpoint);
# set COMPRESS_BASE_URL here and reference ${COMPRESS_BASE_URL} in yaml if you need to vary it.
COMPRESS_API_KEY=sk-xxxx

# ---- mem0 SaaS SDK (cloud mode) ----
MEM0_API_KEY=m0-zxxxxx

# ---- 服务于mem0自托管服务的数据库 ----
# neonDB 的postgres连接字符串示例：
# 注意：注意把连接字符串里的参数'-pooler'删除，并且末尾添加'options=endpoint%3Dep-nameless-brook-anb8vqsy'，替换掉管道'channel_binding=require'
# https://console.neon.tech
DB_MEMORY_URL=postgresql://USER:PASSWORD@s-brook-b8vqsy.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&options=endpoint%3Dep-nameless-brook-anb8vqsy

# ---- 服务于存储聊天数据的数据库 ----
# neonDB 的postgres连接字符串示例（请替换为实际值）：
# https://console.neon.tech
DB_STORAGE_URL=postgresql://neondb_owner:nxxxx2hlc1w-xxxxneon.tech/neondb?sslxxxx

# ---- Phase 11 authentication ----
# 在 config/auth.yaml 中启用身份验证之前，生成一个很长的随机值。
JWT_SECRET_KEY=replace-with-a-long-random-secret

# GitHub OAuth App settings.
GITHUB_CLIENT_ID=Iv1.xxxxx
GITHUB_CLIENT_SECRET=github_oauth_client_secret

