# Environment variables for atri
# This file is git-ignored; never commit real secrets.
# Loaded by src/main.py at startup via python-dotenv.

# ---- Main chat LLM (OpenAI-compatible; currently SiliconFlow) ----
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2

# ---- L3/L4 compression LLM ----
# base_url currently hard-coded in config/llm_config.yaml (same endpoint);
# set COMPRESS_BASE_URL here and reference ${COMPRESS_BASE_URL} in yaml if you need to vary it.
COMPRESS_API_KEY=sk-xxxx

# ---- mem0 SaaS SDK (cloud mode) ----
MEM0_API_KEY=m0-zxxxxx

# ---- 服务于mem0自托管服务的数据库 ----
# neonDB 的postgres连接字符串示例（请替换为实际值）：
# https://console.neon.tech
DB_NEON_URL=postgresql://neondb_owner:nxxxx2hlc1w-xxxxneon.tech/neondb?sslxxxx

# ---- TTS SDK API ----
# 默认硅基流动
SILICONFLOW_API_KEY=sk-xxxx

# ---- Phase 11 authentication ----
# Generate a long random value before enabling auth in config/auth.yaml.
JWT_SECRET_KEY=replace-with-a-long-random-secret

# GitHub OAuth App settings.
GITHUB_CLIENT_ID=Iv1.xxxxx
GITHUB_CLIENT_SECRET=github_oauth_client_secret
